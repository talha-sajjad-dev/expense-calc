# Supabase (required)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your_anon_key
SUPABASE_DB_URL=postgresql://postgres:PASSWORD@db.YOUR_REF.supabase.co:5432/postgres

# Supabase service role — required for email notifications (Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJ...your_service_role_key

# Gmail SMTP — free, sends to any address (no domain verification)
# 1. Google Account → Security → 2-Step Verification (enable)
# 2. Google Account → Security → App passwords → generate for "Mail"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=talha.sajjad@qbatch.com
SMTP_PASS=ubgz zatr gavx knph
EMAIL_FROM=SplitFlat

# Public app URL for links in emails (set in Vercel env for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
